{
  "name": "inkscii",
  "author": "involvex",
  "type": "module",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/involvex"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/involvex"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run build:cli && bun run build:ascii && bun run build:text",
    "build:cli": "bun run --cwd packages/cli build",
    "build:ascii": "bun run --cwd packages/inkscii-ascii build",
    "build:text": "bun run --cwd packages/react-ascii-text build",
    "test": "bun run --cwd packages/cli test && bun run --cwd packages/inkscii-ascii test",
    "lint": "eslint packages/*/src",
    "lint:fix": "eslint packages/*/src --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "clean": "rm -rf node_modules packages/*/dist packages/*/node_modules"
  },
  "version": "0.0.1",
  "dependencies": {
    "has-flag": "^5.0.1",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "meow": "^14.1.0",
    "react": "^19.2.4",
    "react-devtools-core": "^7.0.1",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@tsconfig/bun": "1.0.10",
    "@tsconfig/node22": "22.0.5",
    "@types/bun": "1.3.10",
    "@types/ink": "^2.0.3",
    "@types/meow": "^6.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "chalk": "^5.2.0",
    "conventional-changelog-cli": "^5.0.0",
    "del-cli": "^7.0.0",
    "eslint": "latest",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "ink-testing-library": "^4.0.0",
    "jiti": "latest",
    "prettier": "latest",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-sort-imports": "^1.8.10",
    "typescript": "^5.7.3",
    "typescript-eslint": "latest"
  },
  "prettier": "@involvex/prettier-config",
  "packageManager": "bun@1.3.10"
}